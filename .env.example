# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
BETTER_AUTH_SECRET=""

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cardora-remake-next"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Razorpay - Required for payments
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# SMTP (Email) - Optional, password reset emails logged to console if not set
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
