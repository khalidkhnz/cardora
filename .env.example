# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
BETTER_AUTH_SECRET=""

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cardora-remake-next"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe - Required for payments
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# SMTP (Email) - Optional, password reset emails logged to console if not set
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
