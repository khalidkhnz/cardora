# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth
BETTER_AUTH_SECRET=""

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cardora-remake-next"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Frontend domain for QR codes / profile links (e.g. https://cardora.com)
NEXT_PUBLIC_FE_BASE_URL=""

# Razorpay - Required for payments
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# AWS S3 - Required for file uploads
AWS_S3_BUCKET=""
AWS_S3_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional: CloudFront CDN URL (e.g. https://cdn.example.com)
# AWS_S3_CDN_URL=""

# SMTP (Email) - Optional, password reset emails logged to console if not set
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
